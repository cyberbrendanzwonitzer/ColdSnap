PORT=3000
CORS_ORIGIN=*
DATA_MODE=postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cryochamber
DB_SSL=false
CRM_PROVIDER=mock
BOOKING_PROVIDER=mock
REMINDER_PROVIDER=mock
# Supported reminder providers: mock, gmail, resend, none
REMINDER_FALLBACK_PROVIDER=
# Optional fallback when primary reminder provider fails (example: resend)
ALLOW_OUTBOUND_INTEGRATIONS=false
HUBSPOT_ACCESS_TOKEN=
GHL_API_KEY=
GHL_LOCATION_ID=
BOOKING_API_KEY=
BOOKING_BASE_URL=
REMINDER_LEAD_MINUTES=0
REMINDER_POLL_MS=60000
REMINDER_RETRY_MINUTES=15
REMINDER_TIMEZONE=America/New_York
REMINDER_FROM_EMAIL=
REMINDER_FROM_NAME=CryoChamber
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_HOST=smtp.gmail.com
GMAIL_PORT=465
GMAIL_SECURE=true
GMAIL_PREFER_IPV4=true
GMAIL_CONNECTION_TIMEOUT_MS=20000
GMAIL_GREETING_TIMEOUT_MS=15000
GMAIL_SOCKET_TIMEOUT_MS=30000
RESEND_API_KEY=
DATA_FILE=data/runtime.json
